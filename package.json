{
  "name": "momentum-game",
  "version": "1.0.0",
  "description": "Innovation center icebreaker board game MVP",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm --prefix client run dev\"",
    "server:dev": "cd server && node --watch server.js",
    "client:dev": "npm --prefix client run dev",
    "client:build": "npm --prefix client run build",
    "build": "npm run client:build",
    "test": "node --test server/tests/game-helpers.test.js",
    "start": "cd server && NODE_ENV=production node server.js",
    "seed-prompts": "cd server && node scripts/seed-prompts.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
